{
  "name": "expense-tracker",
  "private": true,
  "description": "Root helpers: PM2 process manager for API + Vite client",
  "scripts": {
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "build:client": "npm run build --prefix client",
    "rebuild": "pm2 restart ecosystem.config.cjs",
    "rebuild:client": "npm run build --prefix client && pm2 restart expense-client"
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}
