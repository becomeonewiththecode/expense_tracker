# HTTP origin (protocol, host, and port) where the Express API listens during development.
# This value must match the PORT value in server/.env so Vite can proxy /api requests to the correct server.
API_PROXY_TARGET=http://127.0.0.1:4000

# OAuth redirect URLs and CLIENT_ORIGIN are configured in server/.env on the API, not in this file.
# The client only needs API_PROXY_TARGET so that browser requests to paths like /api/auth/oauth/... reach the Express server through the Vite proxy.
