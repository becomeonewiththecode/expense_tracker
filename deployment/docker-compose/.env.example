# Copy to .env next to docker-compose.yml and edit. Never commit real secrets.

# Public URL of the web UI (scheme + host + port, no path). Must match what users type in the browser.
# Example when publishing port 8080 on localhost:
CLIENT_ORIGIN=http://localhost:8080

# Required for production Compose (16+ characters). If empty, `npm run compose:prod` runs
# `node deployment/docker-compose/ensure-env.mjs` first and fills this automatically on the host
# (same file the api container loads via env_file — stable across rebuilds). You can also run:
#   openssl rand -base64 32
# and paste manually. Do not commit .env.
JWT_SECRET=

# Optional: host port mapped to nginx (default 8080)
HTTP_PORT=8080

# PostgreSQL (defaults match docker-compose service names)
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_DB=expense_tracker

# OAuth — leave empty if not using single sign-on
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITLAB_CLIENT_ID=
OAUTH_GITLAB_CLIENT_SECRET=
OAUTH_GITLAB_BASE_URL=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=
