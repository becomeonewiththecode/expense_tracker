# TCP port where the Express HTTP server listens.
PORT=4000

# PostgreSQL connection string used by the API (host, database name, user, password).
DATABASE_URL=postgresql://expense:expense@localhost:5432/expense_tracker

# Redis connection string for optional report caching. If unset, reports are not cached in Redis.
REDIS_URL=redis://localhost:6379

# Secret key used to sign JSON Web Tokens. Change this in production to a long random string.
JWT_SECRET=change-me-in-production-use-long-random-string

# Base URL of the single-page application as seen in the browser: scheme, host, and port only, with no path and no trailing slash.
# Used for Cross-Origin Resource Sharing configuration and for OAuth redirect URLs after login.
CLIENT_ORIGIN=http://localhost:5173

# --- OAuth and single sign-on (optional) ---
#
# For each identity provider, create an OAuth application and set the authorized redirect URL to exactly:
#   {CLIENT_ORIGIN}/api/auth/oauth/google/callback
#   {CLIENT_ORIGIN}/api/auth/oauth/github/callback
#   {CLIENT_ORIGIN}/api/auth/oauth/gitlab/callback
#   {CLIENT_ORIGIN}/api/auth/oauth/microsoft/callback
#
# Replace {CLIENT_ORIGIN} with the same value as CLIENT_ORIGIN above, for example:
#   http://localhost:5173/api/auth/oauth/google/callback
#
# Optional: base URL for a self-hosted GitLab instance (defaults to https://gitlab.com if unset).
# OAUTH_GITLAB_BASE_URL=https://gitlab.com
#
# Optional: Microsoft Entra (Azure AD) tenant identifier (defaults to "common" for multi-tenant if unset).
# OAUTH_MICROSOFT_TENANT=common
#
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GITLAB_CLIENT_ID=
# OAUTH_GITLAB_CLIENT_SECRET=
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=
